---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = (d: Date) => new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long", day: "numeric" }).format(d);
---

<Base title={`${entry.data.title} — Sen He`} description={entry.data.summary} dimBg={true}>
  <article class="section" style="padding-top:clamp(7rem,12vw,10rem);">
    <div class="wrap" style="max-width:55rem;">
      <p class="eyebrow reveal">{fmt(entry.data.date)}</p>
      <h1 class="reveal" style="max-width:22ch;margin-bottom:2rem;">{entry.data.title}</h1>
      <div class="prose reveal"><Content /></div>
      <a href="/blog" class="link reveal" style="display:inline-block;margin-top:2.75rem;">← All posts</a>
    </div>
  </article>
</Base>
