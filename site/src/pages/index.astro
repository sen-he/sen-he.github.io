---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const allPubs = (await getCollection("publications")).map((p) => p.data);
const featured = allPubs
  .filter((p) => p.featured)
  .sort((a, b) => b.year - a.year)
  .slice(0, 5);

const research = [
  {
    n: "01",
    title: "Multi-Agent LLM Orchestration",
    body: "Collaborative multi-agent architectures that leverage frontier LLMs for code generation, debugging, and refinement.",
  },
  {
    n: "02",
    title: "Software Performance Engineering",
    body: "Performance-testing methodologies for cloud environments, serverless platforms, and edge/fog computing systems.",
  },
  {
    n: "03",
    title: "AI-Driven Software Testing",
    body: "Harnessing LLMs to automatically test complex systems, from VR applications to cloud-native architectures.",
  },
  {
    n: "04",
    title: "Efficient Computer Vision",
    body: "Applied work in medical image segmentation, brain-connectivity analysis, and 3D vision.",
  },
];

---

<Base>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <p class="eyebrow reveal">Assistant Professor · ECE · University of Arizona</p>
        <h1 class="display hero-name">
          <span class="line"><span>Sen</span></span>
          <span class="line"><span>He</span></span>
        </h1>
        <p class="lead reveal hero-lead">
          I build <span class="mark">agentic systems</span> for software
          engineering, and study how AI can <strong>test, debug, and
          optimize</strong> the software the world runs on.
        </p>
        <div class="hero-cta reveal">
          <a href="#publications" class="btn btn-primary">View publications</a>
        </div>
        <nav class="hero-links reveal" aria-label="Professional profiles">
          <a class="chip" href="https://ece.engineering.arizona.edu/faculty-staff/faculty/sen-he" target="_blank" rel="noopener">University of Arizona</a>
          <a class="chip" href="https://scholar.google.com/citations?user=ySPHD4cAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>
          <a class="chip" href="https://dblp.org/pid/166/4467-2.html" target="_blank" rel="noopener">DBLP</a>
          <span class="chip-break" aria-hidden="true"></span>
          <a class="chip" href="https://orcid.org/0000-0002-5204-8976" target="_blank" rel="noopener">ORCID</a>
          <a class="chip" href="https://www.researchgate.net/profile/Sen-He-3" target="_blank" rel="noopener">ResearchGate</a>
          <a class="chip" href="https://www.linkedin.com/in/sen-he-cloud/" target="_blank" rel="noopener">LinkedIn</a>
          <a class="chip" href="https://github.com/sen-he" target="_blank" rel="noopener">GitHub</a>
        </nav>
      </div>

      <div class="hero-avatar reveal" data-parallax="-12">
        <img src="/me.webp" alt="Sen He" width="320" height="320" fetchpriority="high" />
      </div>
    </div>

    <div class="scroll-hint" aria-hidden="true">scroll ↓</div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section class="section" id="about">
    <div class="wrap about-grid">
      <p class="eyebrow reveal">About</p>
      <p class="about-lead reveal">
        My research lies at the intersection of <span class="hl hl-1">AI for software
        engineering</span>, <span class="hl hl-2">efficient computer vision</span>, and{" "}
        <span class="hl hl-3">human-computer interaction</span>. I am especially
        interested in how large language models can be <span class="hl hl-4">orchestrated as
        multi-agent systems</span> to solve complex engineering tasks, from
        automated code generation to performance optimization.
      </p>
    </div>
  </section>

  <!-- ============ RESEARCH ============ -->
  <section class="section research" id="research">
    <div class="wrap">
      <p class="eyebrow reveal">Research</p>
      <h2 class="reveal" style="margin-bottom:2.5rem;">Four thrusts, one question: how do we let AI build better software?</h2>
      <div class="research-grid">
        {research.map((r) => (
          <article class="card reveal">
            <span class="card-n">{r.n}</span>
            <h3>{r.title}</h3>
            <p>{r.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PUBLICATIONS ============ -->
  <section class="section" id="publications">
    <div class="wrap">
      <p class="eyebrow reveal">Selected work</p>
      <h2 class="reveal" style="margin-bottom:2.5rem;">Recent publications</h2>
      <ul class="pub-list">
        {featured.map((p) => (
          <li class="pub reveal">
            <span class="pub-venue">{p.year}</span>
            <div>
              {p.doi ? (
                <a class="pub-title" href={`https://doi.org/${p.doi}`}>{p.title}</a>
              ) : (
                <span class="pub-title">{p.title}</span>
              )}
              <p class="pub-meta">
                {p.authors.map((a, i) => (
                  <span class={a === "Sen He" ? "me" : undefined}>{a}{i < p.authors.length - 1 ? ", " : ""}</span>
                ))}
                {" · "}<em>{p.venue}</em>
              </p>
            </div>
          </li>
        ))}
      </ul>
      <a href="/publications/all" class="link reveal" style="display:inline-block;margin-top:1.5rem;">All publications →</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-block: 8rem 4rem;
    overflow: hidden;
  }
  /* scrim: keeps the copy readable over the bold neon background */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: linear-gradient(
      100deg,
      var(--bg) 20%,
      color-mix(in srgb, var(--bg) 55%, transparent) 44%,
      transparent 68%
    );
  }
  .hero > .wrap { position: relative; z-index: 1; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.9fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .hero-name { margin: 0 0 1.75rem; }
  .hero .line { line-height: 1.06; }
  .hero-lead { max-width: 32ch; color: var(--muted); }
  .hero-lead strong { color: var(--accent); }
  :root[data-theme="dark"] .hero-lead strong { color: var(--accent-2); }
  .hero-cta { display: flex; gap: 0.9rem; margin-top: 2rem; flex-wrap: wrap; }
  /* round photo inside a green liquid-glass frame */
  .hero-avatar {
    position: relative;
    isolation: isolate;
    width: min(330px, 74%);
    aspect-ratio: 1;
    margin-inline: auto;
    padding: 15px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--accent) 55%, var(--glass-border));
    background: color-mix(in srgb, var(--accent) 12%, var(--glass));
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    box-shadow: inset 0 1px 0 var(--glass-highlight),
      0 0 50px -10px color-mix(in srgb, var(--accent) 70%, transparent),
      var(--glass-shadow);
  }
  .hero-avatar::before {
    content: "";
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    border-radius: 50%;
    background: linear-gradient(150deg, var(--glass-highlight) 0%, transparent 46%);
  }
  .hero-avatar img {
    width: 100%;
    height: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }
  .scroll-hint {
    position: absolute;
    z-index: 1;
    bottom: 1.6rem;
    left: var(--pad);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .about-grid { display: grid; gap: 1.5rem; }
  .about-lead {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.6rem, 1rem + 3vw, 3.2rem);
    line-height: 1.18;
    letter-spacing: -0.015em;
    max-width: 22ch;
    text-wrap: balance;
    /* soft halo in the page bg colour: invisible over the flat background, but
       keeps the colored phrases legible if a bright saguaro node drifts behind */
    text-shadow: 0 0 14px var(--bg);
  }
  /* "multi-agent systems" matches the ABOUT eyebrow; 3 interests = 3 other greens */
  .about-lead .hl { font-style: italic; }
  .about-lead .hl-4 { color: var(--accent); } /* same as the "ABOUT" eyebrow */
  .about-lead .hl-1 { color: #467d18; } /* lime */
  .about-lead .hl-2 { color: #1f7a48; } /* emerald */
  .about-lead .hl-3 { color: #136b5c; } /* teal */
  :root[data-theme="dark"] .about-lead .hl-1 { color: #7cc83c; }
  :root[data-theme="dark"] .about-lead .hl-2 { color: #3fc46a; }
  :root[data-theme="dark"] .about-lead .hl-3 { color: #2bc0b0; }

  /* hero professional-profile chips */
  .hero-links { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.25rem; max-width: 34rem; }
  .chip-break { flex-basis: 100%; height: 0; }
  .chip {
    font-size: 0.8rem; font-weight: 500;
    padding: 0.4rem 0.85rem; border-radius: 0.7rem;
    text-decoration: none; color: var(--ink);
    border: 1px solid var(--glass-border); background: var(--glass-strong);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    box-shadow: inset 0 1px 0 var(--glass-highlight), 0 4px 12px -4px rgba(0, 0, 0, 0.35);
    transition: transform 0.2s var(--ease), border-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .chip:hover { transform: translateY(-2px); border-color: color-mix(in srgb, var(--accent) 60%, transparent); color: var(--accent); }
  :root[data-theme="dark"] .chip:hover { color: var(--accent-2); }

  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
    gap: 1.25rem;
  }
  .card {
    position: relative;
    padding: 1.75rem;
    border: 1px solid var(--glass-border);
    border-radius: 1.25rem;
    background: var(--glass-strong);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    box-shadow: inset 0 1px 0 var(--glass-highlight), var(--glass-shadow);
    overflow: hidden;
    transition: transform 0.3s var(--ease), border-color 0.3s var(--ease),
      box-shadow 0.3s var(--ease);
  }
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(150deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0) 42%);
  }
  :root[data-theme="dark"] .card::before {
    background: linear-gradient(150deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0) 42%);
  }
  .card > * { position: relative; }
  .card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    box-shadow: inset 0 1px 0 var(--glass-highlight), 0 18px 40px -16px rgba(0, 0, 0, 0.45);
  }
  .card-n { font-family: var(--font-mono); font-size: 0.8rem; color: var(--accent); }
  :root[data-theme="dark"] .card-n { color: var(--accent-2); }
  .card h3 { margin: 0.6rem 0 0.5rem; }
  .card p { color: var(--muted); font-size: 0.97rem; }

  .pub-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .pub {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 1.5rem;
    padding: 1.4rem 1.6rem;
    border-radius: 1.1rem;
    border: 1px solid var(--glass-border);
    background: var(--glass-strong);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    box-shadow: inset 0 1px 0 var(--glass-highlight), var(--glass-shadow);
    align-items: baseline;
    transition: transform 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .pub::before {
    content: "";
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(150deg, var(--glass-highlight) 0%, transparent 36%);
  }
  .pub > * { position: relative; }
  .pub:hover { transform: translateY(-3px); border-color: color-mix(in srgb, var(--accent) 55%, transparent); }
  .pub-venue { font-family: var(--font-mono); font-size: 0.82rem; color: var(--accent); padding-top: 0.4rem; }
  :root[data-theme="dark"] .pub-venue { color: var(--accent-2); }
  .pub-title { font-family: var(--font-display); font-size: clamp(1.1rem, 0.9rem + 1vw, 1.5rem); line-height: 1.2; color: inherit; text-decoration: none; display: inline-block; }
  a.pub-title { transition: color 0.2s var(--ease); }
  a.pub-title:hover { color: var(--accent); }
  :root[data-theme="dark"] a.pub-title:hover { color: var(--accent-2); }
  .pub-meta { color: var(--muted); font-size: 0.85rem; margin-top: 0.5rem; line-height: 1.5; }
  .pub-meta .me { color: var(--ink); font-weight: 600; }
  .pub-meta em { font-style: italic; }

  @media (max-width: 820px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-avatar { order: -1; width: min(230px, 58%); padding: 12px; }
    .pub { grid-template-columns: 1fr; gap: 0.5rem; padding: 1.2rem 1.3rem; }
    /* full-width copy needs a vertical scrim, not a left one */
    .hero::before {
      background: linear-gradient(
        180deg,
        transparent 0%,
        color-mix(in srgb, var(--bg) 55%, transparent) 42%,
        var(--bg) 76%
      );
    }
  }
</style>
