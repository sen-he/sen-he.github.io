---
import Base from "../layouts/Base.astro";

const research = [
  {
    n: "01",
    title: "Multi-Agent LLM Orchestration",
    body: "Collaborative multi-agent architectures that leverage frontier LLMs for code generation, debugging, and refinement.",
  },
  {
    n: "02",
    title: "Software Performance Engineering",
    body: "Performance-testing methodologies for cloud environments, serverless platforms, and edge/fog computing systems.",
  },
  {
    n: "03",
    title: "AI-Driven Software Testing",
    body: "Harnessing LLMs to automatically test complex systems, from VR applications to cloud-native architectures.",
  },
  {
    n: "04",
    title: "Computer Vision",
    body: "Applied work in medical image segmentation, brain-connectivity analysis, and 3D vision.",
  },
];

const papers = [
  { venue: "HICSS 2026", title: "UWB-PostureGuard: A Privacy-Preserving RF Sensing System for Continuous Ergonomic Sitting Posture Monitoring" },
  { venue: "2026", title: "Performance analysis of AI-generated code: a study of Copilot, Copilot Chat, CodeLlaMa, and DeepSeek-Coder" },
  { venue: "2025", title: "GraphQL-Aware Healing in Service-Oriented Architectures via Multi-Signal Learning" },
];
---

<Base>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="blob blob-1" data-parallax="40" aria-hidden="true"></div>
    <div class="blob blob-2" data-parallax="-30" aria-hidden="true"></div>

    <div class="wrap hero-grid">
      <div class="hero-copy">
        <p class="eyebrow reveal">Assistant Professor · ECE · University of Arizona</p>
        <h1 class="display hero-name">
          <span class="line"><span>Sen</span></span>
          <span class="line"><span>He</span></span>
        </h1>
        <p class="lead reveal hero-lead">
          I build <span class="mark">multi-agent LLM systems</span> for software
          engineering, and study how AI can <strong>test, debug, and optimize</strong>
          the software the world runs on.
        </p>
        <div class="hero-cta reveal">
          <a href="#publications" class="btn btn-primary">View publications</a>
          <a href="mailto:senhe@arizona.edu" class="btn">Get in touch</a>
        </div>
      </div>

      <div class="hero-avatar reveal" data-parallax="-12">
        <img src="/me.png" alt="Sen He" width="320" height="320" />
      </div>
    </div>

    <div class="scroll-hint" aria-hidden="true">scroll ↓</div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section class="section" id="about">
    <div class="wrap about-grid">
      <p class="eyebrow reveal">About</p>
      <p class="about-lead reveal">
        My research lies at the intersection of <span class="mark">AI for software
        engineering</span>, <span class="mark">computer vision</span>, and
        <span class="mark">human-computer interaction</span>. I am especially
        interested in how large language models can be <strong>orchestrated as
        multi-agent systems</strong> to solve complex engineering tasks, from
        automated code generation to performance optimization.
      </p>
    </div>
  </section>

  <!-- ============ RESEARCH ============ -->
  <section class="section research" id="research">
    <div class="wrap">
      <p class="eyebrow reveal">Research</p>
      <h2 class="reveal" style="margin-bottom:2.5rem;">Four thrusts, one question: how do we let AI build better software?</h2>
      <div class="research-grid">
        {research.map((r) => (
          <article class="card reveal">
            <span class="card-n">{r.n}</span>
            <h3>{r.title}</h3>
            <p>{r.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PUBLICATIONS ============ -->
  <section class="section" id="publications">
    <div class="wrap">
      <p class="eyebrow reveal">Selected work</p>
      <h2 class="reveal" style="margin-bottom:2.5rem;">Recent publications</h2>
      <ul class="pub-list">
        {papers.map((p) => (
          <li class="pub reveal">
            <span class="pub-venue">{p.venue}</span>
            <span class="pub-title">{p.title}</span>
          </li>
        ))}
      </ul>
      <a href="https://scholar.google.com/citations?user=ySPHD4cAAAAJ&hl=en" class="link reveal" style="display:inline-block;margin-top:1.5rem;">See all on Google Scholar →</a>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-block: 8rem 4rem;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.9fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .hero-name { margin: 0 0 1.75rem; }
  .hero .line { line-height: 1.06; }
  .hero-lead { max-width: 32ch; color: var(--muted); }
  .hero-lead strong { color: var(--accent); }
  :root[data-theme="dark"] .hero-lead strong { color: var(--accent-2); }
  .hero-cta { display: flex; gap: 0.9rem; margin-top: 2rem; flex-wrap: wrap; }
  .hero-avatar img {
    width: 100%;
    max-width: 340px;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 1.5rem;
    border: 1px solid var(--border);
    box-shadow: 0 30px 60px -30px rgba(0, 0, 0, 0.4);
    margin-inline: auto;
  }
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    z-index: -1;
  }
  .blob-1 { width: 38vw; height: 38vw; background: var(--accent-bright); opacity: 0.18; top: -8vw; right: -6vw; }
  .blob-2 { width: 30vw; height: 30vw; background: var(--accent-2); opacity: 0.12; bottom: -10vw; left: -8vw; }
  :root[data-theme="dark"] .blob-1 { opacity: 0.22; }
  :root[data-theme="dark"] .blob-2 { opacity: 0.16; }
  .scroll-hint {
    position: absolute;
    bottom: 1.6rem;
    left: var(--pad);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .about-grid { display: grid; gap: 1.5rem; }
  .about-lead {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.6rem, 1rem + 3vw, 3.2rem);
    line-height: 1.18;
    letter-spacing: -0.015em;
    max-width: 22ch;
    text-wrap: balance;
  }

  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
    gap: 1.25rem;
  }
  .card {
    padding: 1.75rem;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    background: var(--surface);
    transition: transform 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .card:hover { transform: translateY(-4px); border-color: var(--accent); }
  .card-n { font-family: var(--font-mono); font-size: 0.8rem; color: var(--accent); }
  :root[data-theme="dark"] .card-n { color: var(--accent-2); }
  .card h3 { margin: 0.6rem 0 0.5rem; }
  .card p { color: var(--muted); font-size: 0.97rem; }

  .pub-list { list-style: none; padding: 0; }
  .pub {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
    align-items: baseline;
    transition: transform 0.25s var(--ease);
  }
  .pub:last-child { border-bottom: 1px solid var(--border); }
  .pub:hover { transform: translateX(6px); }
  .pub-venue { font-family: var(--font-mono); font-size: 0.82rem; color: var(--accent); }
  :root[data-theme="dark"] .pub-venue { color: var(--accent-2); }
  .pub-title { font-family: var(--font-display); font-size: clamp(1.1rem, 0.9rem + 1vw, 1.5rem); line-height: 1.2; }

  @media (max-width: 820px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-avatar { order: -1; }
    .hero-avatar img { max-width: 200px; }
    .pub { grid-template-columns: 1fr; gap: 0.4rem; }
  }
</style>
