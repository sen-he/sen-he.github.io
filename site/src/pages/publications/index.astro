---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const typeOrder = { journal: 0, conference: 1, preprint: 2 } as Record<string, number>;
const typeLabel = { journal: "Journal", conference: "Conference", preprint: "Preprint" } as Record<string, string>;
// 5 most recent accepted papers (journal + conference; preprints excluded)
const recent = (await getCollection("publications"))
  .map((p) => p.data)
  .filter((p) => p.type !== "preprint")
  .sort(
    (a, b) =>
      b.year - a.year ||
      typeOrder[a.type] - typeOrder[b.type] ||
      a.title.localeCompare(b.title)
  )
  .slice(0, 5);
---

<Base title="Publications — Sen He" description="Recent publications by Sen He, University of Arizona." dimBg={true}>
  <section class="section" style="padding-top:clamp(7rem,12vw,10rem);">
    <div class="wrap">
      <p class="eyebrow reveal">Publications</p>
      <h1 class="reveal" style="margin-bottom:0.5rem;">Recent publications</h1>
      <p class="reveal" style="color:var(--muted);max-width:52ch;margin-bottom:3rem;">
        Five most recent accepted papers. Titles link to the publisher where a
        DOI is available.
      </p>

      <ul class="pub-list">
        {recent.map((p) => (
          <li class="pub reveal">
            <span class={`badge badge-${p.type}`}>{typeLabel[p.type]}</span>
            <div>
              {p.doi ? (
                <a class="pub-title" href={`https://doi.org/${p.doi}`}>{p.title}</a>
              ) : (
                <span class="pub-title">{p.title}</span>
              )}
              <p class="pub-meta">
                {p.authors.map((a, i) => (
                  <span class={a === "Sen He" ? "me" : undefined}>{a}{i < p.authors.length - 1 ? ", " : ""}</span>
                ))}
                {" · "}<em>{p.year}</em>
              </p>
              <p class="pub-venue-line"><em>{p.venue}</em></p>
            </div>
          </li>
        ))}
      </ul>

      <div class="reveal" style="margin-top:2.5rem;display:flex;gap:0.8rem;flex-wrap:wrap;">
        <a class="btn btn-primary" href="/publications/all">All publications</a>
        <a class="btn" href="https://scholar.google.com/citations?user=ySPHD4cAAAAJ&hl=en">Google Scholar</a>
      </div>
      <a href="/" class="link reveal" style="display:inline-block;margin-top:2rem;">← Back home</a>
    </div>
  </section>
</Base>

<style>
  .pub-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .pub {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: 1.25rem;
    padding: 1.3rem 1.5rem;
    border-radius: 1.1rem;
    border: 1px solid var(--glass-border);
    background: var(--glass-strong);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-sat));
    box-shadow: inset 0 1px 0 var(--glass-highlight), var(--glass-shadow);
    align-items: start;
    transition: transform 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .pub::before {
    content: "";
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(150deg, var(--glass-highlight) 0%, transparent 34%);
  }
  .pub > * { position: relative; }
  .pub:hover { transform: translateY(-3px); border-color: color-mix(in srgb, var(--accent) 50%, transparent); }
  .badge {
    justify-self: start;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    padding: 0.3rem 0.65rem;
    border-radius: 0.55rem;
    border: 1px solid var(--glass-border);
    background: var(--glass);
    -webkit-backdrop-filter: blur(10px) saturate(160%);
    backdrop-filter: blur(10px) saturate(160%);
    color: var(--muted);
    white-space: nowrap;
  }
  .badge-journal { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 40%, transparent); }
  :root[data-theme="dark"] .badge-journal { color: var(--accent-2); }
  .pub-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1.25;
    color: inherit;
    text-decoration: none;
    display: inline-block;
    transition: color 0.2s var(--ease);
  }
  a.pub-title:hover { color: var(--accent); }
  :root[data-theme="dark"] a.pub-title:hover { color: var(--accent-2); }
  .pub-meta { color: var(--muted); font-size: 0.9rem; margin-top: 0.4rem; line-height: 1.5; }
  .pub-meta .me { color: var(--ink); font-weight: 600; }
  .pub-venue-line { color: var(--muted); font-size: 0.9rem; margin-top: 0.15rem; }
  @media (max-width: 640px) {
    .pub { grid-template-columns: 1fr; gap: 0.6rem; }
  }
</style>
