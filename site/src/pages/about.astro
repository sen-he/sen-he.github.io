---
import Base from "../layouts/Base.astro";

const interests = [
  "Multi-agent LLM orchestration for software engineering",
  "Software performance engineering for cloud, serverless, and edge systems",
  "AI-driven software testing",
  "Computer vision and medical image analysis",
];
const education = [
  { degree: "Ph.D. in Computer Science", org: "University of Texas at San Antonio" },
];
const links = [
  { label: "Google Scholar", href: "https://scholar.google.com/citations?user=ySPHD4cAAAAJ&hl=en" },
  { label: "GitHub", href: "https://github.com/sen-he" },
  { label: "CV", href: "/cv" },
];
---

<Base title="About — Sen He" description="About Sen He, Assistant Professor of ECE at the University of Arizona." dimBg={true}>
  <section class="section" style="padding-top:clamp(7rem,12vw,10rem);">
    <div class="wrap" style="max-width:60rem;">
      <p class="eyebrow reveal">About</p>
      <div class="about-head reveal">
        <img src="/me.png" alt="Sen He" width="160" height="160" />
        <div>
          <h1 style="margin-bottom:0.75rem;">Sen He</h1>
          <p class="lede">
            Assistant Professor, Department of Electrical &amp; Computer
            Engineering, University of Arizona.
          </p>
        </div>
      </div>

      <div class="prose reveal" style="margin-top:2.5rem;">
        <p>
          I build <strong>agentic systems</strong> for software
          engineering and study how AI can test, debug, and optimize the
          software the world runs on. My work spans AI for software
          engineering, computer vision, and human-computer interaction. Before
          Arizona I taught at Augusta University.
        </p>
      </div>

      <div class="cols">
        <div class="reveal">
          <h2 class="sub">Research interests</h2>
          <ul class="plain">{interests.map((i) => <li>{i}</li>)}</ul>
        </div>
        <div class="reveal">
          <h2 class="sub">Education</h2>
          <ul class="plain">{education.map((e) => <li><strong>{e.degree}</strong><br />{e.org}</li>)}</ul>
          <h2 class="sub" style="margin-top:2rem;">Elsewhere</h2>
          <div class="linkrow">{links.map((l) => <a class="btn" href={l.href}>{l.label}</a>)}</div>

          <h2 class="sub" style="margin-top:2rem;">Contact</h2>
          <p class="email" aria-label="Email address, written out to deter spam bots">
            senhe<span> [at] </span>arizona<span> [dot] </span>edu
          </p>
        </div>
      </div>

      <a href="/" class="link reveal" style="display:inline-block;margin-top:3rem;">← Back home</a>
    </div>
  </section>
</Base>

<style>
  .about-head { display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap; }
  .about-head img { width: 110px; height: 110px; border-radius: 1.25rem; object-fit: cover; border: 1px solid var(--glass-border); }
  .lede { color: var(--muted); font-size: 1.1rem; max-width: 40ch; }
  .cols { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; margin-top: 3rem; }
  .sub { font-family: var(--font-mono); font-size: 0.9rem; color: var(--accent); letter-spacing: 0.06em; margin-bottom: 1rem; }
  :root[data-theme="dark"] .sub { color: var(--accent-2); }
  .plain { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.85rem; color: var(--ink); line-height: 1.5; }
  .plain strong { color: var(--ink); }
  .linkrow { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .email { font-family: var(--font-mono); font-size: 0.95rem; color: var(--ink); }
  .email span { color: var(--muted); }
  @media (max-width: 720px) { .cols { grid-template-columns: 1fr; gap: 2rem; } }
</style>
