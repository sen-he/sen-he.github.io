---
// The PDF itself is provided separately: drop resume.pdf into site/public/
// and the button below ("/resume.pdf") will serve it.
import Base from "../layouts/Base.astro";

const highlights = [
  { k: "Position", v: "Assistant Professor, ECE, University of Arizona" },
  { k: "Education", v: "Ph.D. in Computer Science, University of Texas at San Antonio" },
  { k: "Areas", v: "AI for software engineering · performance engineering · efficient computer vision" },
];
---

<Base title="CV — Sen He" description="Curriculum vitae of Sen He." dimBg={true}>
  <section class="section" style="padding-top:clamp(7rem,12vw,10rem);">
    <div class="wrap" style="max-width:48rem;">
      <p class="eyebrow reveal">Curriculum Vitae</p>
      <h1 class="reveal" style="margin-bottom:1.5rem;">CV</h1>

      <div class="gcard reveal" style="padding:1.75rem 2rem;margin-bottom:2rem;">
        <dl class="cvlist">
          {highlights.map((h) => (
            <div class="row">
              <dt>{h.k}</dt>
              <dd>{h.v}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="reveal" style="display:flex;gap:0.8rem;flex-wrap:wrap;align-items:center;">
        <a class="btn btn-primary" href="/resume.pdf" target="_blank" rel="noopener">Download CV (PDF)</a>
        <a class="btn" href="/publications">Publications</a>
      </div>
      <p class="reveal" style="color:var(--muted);font-size:0.85rem;margin-top:1.25rem;">
        For the full record, see my <a class="link" href="https://scholar.google.com/citations?user=ySPHD4cAAAAJ&hl=en">Google Scholar</a> profile.
      </p>

      <a href="/" class="link reveal" style="display:inline-block;margin-top:2.5rem;">← Back home</a>
    </div>
  </section>
</Base>

<style>
  .cvlist { margin: 0; }
  .row { display: grid; grid-template-columns: 8rem 1fr; gap: 1rem; padding: 0.7rem 0; }
  .row + .row { border-top: 1px solid var(--glass-border); }
  dt { font-family: var(--font-mono); font-size: 0.8rem; color: var(--accent); }
  :root[data-theme="dark"] dt { color: var(--accent-2); }
  dd { margin: 0; color: var(--ink); }
  @media (max-width: 560px) { .row { grid-template-columns: 1fr; gap: 0.25rem; } }
</style>
