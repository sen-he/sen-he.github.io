---
interface Props {
  title?: string;
  description?: string;
  dimBg?: boolean;
}
const {
  title = "Sen He — Assistant Professor, ECE, University of Arizona",
  description = "Sen He, Assistant Professor of Electrical & Computer Engineering at the University of Arizona. Research in multi-agent LLM orchestration, software performance engineering, and computer vision.",
  dimBg = false,
} = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (function () {
        try {
          // default to dark; respect an explicit stored choice
          document.documentElement.dataset.theme =
            localStorage.getItem("theme") || "dark";
        } catch (e) {
          document.documentElement.dataset.theme = "dark";
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,900&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <canvas id="bg" class="bg-canvas" aria-hidden="true"></canvas>
    <div class="bg-grain" aria-hidden="true"></div>
    {dimBg && <div class="bg-dim" aria-hidden="true"></div>}
    <div class="scroll-progress" aria-hidden="true"></div>

    <nav class="nav">
      <a href="/" class="nav-brand">Home</a>
      <div class="nav-right">
        <div class="nav-links" id="nav-links">
          <a href="/projects">Projects</a>
          <a href="/publications">Publications</a>
          <a href="/team">Team</a>
          <a href="/teaching">Teaching</a>
          <a href="/blog">News</a>
          <a href="/about">About</a>
          <a href="/cv">CV</a>
        </div>
        <button class="icon-btn" data-theme-toggle aria-label="Toggle light and dark mode">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
        </button>
        <button class="icon-btn nav-toggle" data-menu-toggle aria-label="Open menu" aria-expanded="false" aria-controls="nav-links">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"></path></svg>
        </button>
      </div>
    </nav>

    <main><slot /></main>

    <footer class="footer">
      <div class="wrap" style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:space-between;align-items:center;">
        <span>© {new Date().getFullYear()} Sen He · University of Arizona</span>
        <span style="font-family:var(--font-mono);font-size:0.8rem;">Design &amp; content generated by Claude Code</span>
      </div>
    </footer>

    <script>
      const nav = document.querySelector(".nav");
      const prog = document.querySelector<HTMLElement>(".scroll-progress");
      const setNav = (y: number) => nav?.classList.toggle("scrolled", y > 8);
      const setProg = (p: number) => {
        if (prog) prog.style.transform = `scaleX(${Math.min(1, Math.max(0, p))})`;
      };

      // mobile menu
      const menuBtn = document.querySelector("[data-menu-toggle]");
      menuBtn?.addEventListener("click", () => {
        const open = nav?.classList.toggle("menu-open");
        menuBtn.setAttribute("aria-expanded", open ? "true" : "false");
      });
      document.querySelectorAll("#nav-links a").forEach((a) =>
        a.addEventListener("click", () => {
          nav?.classList.remove("menu-open");
          menuBtn?.setAttribute("aria-expanded", "false");
        })
      );

      // theme toggle
      document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
        const next =
          document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        try {
          localStorage.setItem("theme", next);
        } catch (e) {}
        dispatchEvent(new Event("themechange"));
      });

      // nav + progress from native scroll — works regardless of rAF / Lenis.
      // rAF-gated: native scroll + Lenis can fire many events per frame, and each
      // read of scrollHeight/clientHeight forces a synchronous layout. Coalescing
      // to one read per frame keeps fast scrolling from starving the bg animation.
      let scrollQueued = false;
      const readScroll = () => {
        scrollQueued = false;
        const h = document.documentElement;
        const y = window.scrollY || h.scrollTop;
        setProg(y / (h.scrollHeight - h.clientHeight || 1));
        setNav(y);
      };
      const onScroll = () => {
        if (scrollQueued) return;
        scrollQueued = true;
        requestAnimationFrame(readScroll);
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      readScroll();

      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
      // ?nolenis disables smooth-scroll hijacking (used for screenshot verification)
      const noLenis = new URLSearchParams(location.search).has("nolenis");

      if (!reduce) {
        document.documentElement.classList.add("has-anim");

        // stagger via --d
        document
          .querySelectorAll<HTMLElement>(".hero .line")
          .forEach((el, i) => el.style.setProperty("--d", `${i * 120}ms`));
        document
          .querySelectorAll<HTMLElement>(".hero .reveal")
          .forEach((el, i) => el.style.setProperty("--d", `${350 + i * 110}ms`));

        // reveals + marker via IntersectionObserver (no rAF dependency)
        const targets = document.querySelectorAll<HTMLElement>(
          ".reveal, .hero .line, .mark"
        );
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.05 }
        );
        targets.forEach((el) => io.observe(el));
        // watchdog: never let anything stay hidden
        setTimeout(() => targets.forEach((el) => el.classList.add("in")), 2600);

        // smooth scroll + parallax enhancement (degrades to native if rAF idle)
        if (!noLenis)
        Promise.all([import("lenis"), import("gsap"), import("gsap/ScrollTrigger")])
          .then(([{ default: Lenis }, { default: gsap }, { ScrollTrigger }]) => {
            gsap.registerPlugin(ScrollTrigger);
            const lenis = new Lenis({ lerp: 0.1 });
            lenis.on("scroll", () => {
              ScrollTrigger.update();
              onScroll();
            });
            gsap.ticker.add((t) => lenis.raf(t * 1000));
            gsap.ticker.lagSmoothing(0);

            gsap.utils.toArray<HTMLElement>("[data-parallax]").forEach((el) => {
              gsap.to(el, {
                yPercent: parseFloat(el.dataset.parallax || "0"),
                ease: "none",
                scrollTrigger: {
                  trigger: ".hero",
                  start: "top top",
                  end: "bottom top",
                  scrub: true,
                },
              });
            });
          })
          .catch(() => {});
      }
    </script>
    <script>
      // Animated background: a NEON saguaro CONSTELLATION (Tucson) — glowing
      // points sampled from a saguaro silhouette, linked into a network — with
      // drifting neon AI/math symbols over a faint grid. Glow is pre-rendered to
      // offscreen sprites (cheap to composite); flicker is slow. Draws one frame
      // immediately (survives paused rAF / headless); loops only when motion is on.
      const cv = document.getElementById("bg") as HTMLCanvasElement | null;
      const cx = cv && cv.getContext("2d");
      if (cv && cx) {
        const reduceBg = matchMedia("(prefers-reduced-motion: reduce)").matches;
        const DPR = Math.min(window.devicePixelRatio || 1, 3);
        // accumulated animation clock (seconds). Advancing by a *clamped* per-frame
        // delta — never by absolute timestamp — means a frame stall during fast
        // scroll nudges the animation forward instead of jumping, so the saguaro
        // wave/drift stays smooth rather than lurching when rAF is starved.
        let elapsed = 0, last = 0;
        let W = 0, H = 0, dark = true;
        let sag: any = null, syms: any[] = [];
        const SYMS = ["∑","∫","∂","∇","π","λ","θ","∞","Δ","σ","µ","Φ","∮","≈","∝","∈","ℝ","∀","∇θ","P(y|x)","eˣ","wᵀx","argmax","∂L"];

        // build the neon constellation saguaro: sample nodes from the silhouette,
        // link nearby ones, pre-render the glowing lines + a glowing dot sprite
        const buildSaguaro = () => {
          const boxH = Math.min(H * 0.88, 820), boxW = boxH * 0.74, pad = 30;
          const o = document.createElement("canvas"); o.width = 100; o.height = 140;
          const oc = o.getContext("2d")!;
          const bar = (x, y, bw, bh, r) => {
            oc.beginPath(); oc.moveTo(x + r, y);
            oc.arcTo(x + bw, y, x + bw, y + bh, r); oc.arcTo(x + bw, y + bh, x, y + bh, r);
            oc.arcTo(x, y + bh, x, y, r); oc.arcTo(x, y, x + bw, y, r); oc.fill();
          };
          oc.fillStyle = "#fff";
          bar(43, 12, 18, 128, 9); // trunk (tall, dominant)
          bar(24, 84, 25, 15, 7);  // left arm — reaches out
          bar(24, 54, 15, 32, 7);  // left arm — curves up (lower)
          bar(58, 66, 25, 15, 7);  // right arm — reaches out
          bar(68, 36, 15, 32, 7);  // right arm — curves up (higher)
          const d = oc.getImageData(0, 0, 100, 140).data;
          const nodes: any[] = [];
          let tries = 0;
          while (nodes.length < 132 && tries < 11000) {
            tries++;
            const px = Math.floor(Math.random() * 100), py = Math.floor(Math.random() * 140);
            if (d[(py * 100 + px) * 4 + 3] > 12)
              nodes.push({ nx: px / 100, ny: py / 140, ph: Math.random() * 6.28, sp: 0.3 + Math.random() * 0.5 });
          }
          const pairs: any[] = [];
          for (let i = 0; i < nodes.length; i++)
            for (let j = i + 1; j < nodes.length; j++) {
              const dd = Math.hypot(nodes[i].nx - nodes[j].nx, nodes[i].ny - nodes[j].ny);
              if (dd < 0.1) pairs.push([i, j, dd]);
            }
          const col = dark ? "#b6d43a" : "#566b0f";
          // glowing line network
          const lc = document.createElement("canvas");
          lc.width = (boxW + pad * 2) * DPR; lc.height = (boxH + pad * 2) * DPR;
          const lg = lc.getContext("2d")!;
          lg.scale(DPR, DPR); lg.translate(pad, pad);
          lg.strokeStyle = col; lg.shadowColor = col; lg.lineWidth = 1; lg.lineCap = "round";
          for (const pr of pairs) {
            const a = nodes[pr[0]], b = nodes[pr[1]];
            lg.globalAlpha = (dark ? 0.5 : 0.42) * (1 - pr[2] / 0.1);
            lg.shadowBlur = dark ? 7 : 3;
            lg.beginPath(); lg.moveTo(a.nx * boxW, a.ny * boxH); lg.lineTo(b.nx * boxW, b.ny * boxH); lg.stroke();
          }
          // glowing dot sprite
          const ds = 16;
          const dc = document.createElement("canvas");
          dc.width = ds * DPR; dc.height = ds * DPR;
          const dg = dc.getContext("2d")!;
          dg.scale(DPR, DPR);
          dg.fillStyle = dark ? "#dff0a0" : "#3f4e0b"; dg.shadowColor = col;
          dg.globalAlpha = dark ? 0.9 : 0.72; dg.shadowBlur = dark ? 9 : 4;
          dg.beginPath(); dg.arc(ds / 2, ds / 2, 2.1, 0, 6.2832); dg.fill();
          dg.shadowBlur = dark ? 3 : 1; dg.fill();
          sag = { nodes, lineCanvas: lc, lw: boxW + pad * 2, lh: boxH + pad * 2, pad, boxW, boxH, dot: dc, ds };
        };

        const buildSymbol = (ch: string, size: number) => {
          const pad = size * 0.8, dim = Math.ceil(size + pad * 2);
          const c = document.createElement("canvas");
          c.width = dim * DPR; c.height = dim * DPR;
          const g = c.getContext("2d")!;
          g.scale(DPR, DPR);
          const col = dark ? "#b6d43a" : "#4f610e";
          g.font = `${size}px "JetBrains Mono", ui-monospace, monospace`;
          g.textAlign = "center"; g.textBaseline = "middle";
          // dark halo so the symbol reads clearly when it floats over the bright
          // saguaro; invisible over the plain near-black background
          if (dark) {
            const halo = g.createRadialGradient(dim / 2, dim / 2, 0, dim / 2, dim / 2, dim * 0.5);
            halo.addColorStop(0, "rgba(6,8,4,0.62)");
            halo.addColorStop(0.6, "rgba(6,8,4,0.32)");
            halo.addColorStop(1, "rgba(6,8,4,0)");
            g.globalAlpha = 1; g.fillStyle = halo; g.fillRect(0, 0, dim, dim);
          }
          g.fillStyle = col; g.shadowColor = col;
          g.globalAlpha = dark ? 0.6 : 0.42; g.shadowBlur = dark ? 22 : 7; g.fillText(ch, dim / 2, dim / 2);
          g.globalAlpha = dark ? 0.95 : 0.72; g.shadowBlur = dark ? 6 : 2; g.fillText(ch, dim / 2, dim / 2);
          return { canvas: c, dim };
        };
        const buildSymbols = () => {
          syms = [];
          const n = Math.max(9, Math.round((W * H) / 115000));
          for (let i = 0; i < n; i++) {
            const ch = SYMS[Math.floor(Math.random() * SYMS.length)];
            const size = 17 + Math.random() * 24;
            syms.push({ sprite: buildSymbol(ch, size), x: Math.random(), y: Math.random(), ph: Math.random() * 6.28, sp: 0.5 + Math.random() * 0.8, dphx: Math.random() * 6.28, dphy: Math.random() * 6.28 });
          }
        };
        const build = () => { dark = document.documentElement.dataset.theme === "dark"; buildSaguaro(); buildSymbols(); };
        const resize = () => {
          W = innerWidth; H = innerHeight;
          cv.width = W * DPR; cv.height = H * DPR;
          cv.style.width = W + "px"; cv.style.height = H + "px";
          cx.setTransform(DPR, 0, 0, DPR, 0, 0);
          build();
        };

        const draw = (t: number) => {
          cx.clearRect(0, 0, W, H);
          // faint blueprint grid
          cx.globalAlpha = dark ? 0.04 : 0.05;
          cx.strokeStyle = dark ? "#46571f" : "#b9c79a"; cx.lineWidth = 1;
          const step = 68;
          cx.beginPath();
          for (let x = step; x < W; x += step) { cx.moveTo(x, 0); cx.lineTo(x, H); }
          for (let y = step; y < H; y += step) { cx.moveTo(0, y); cx.lineTo(W, y); }
          cx.stroke();
          // neon saguaro constellation
          if (sag) {
            const cxp = W * (W > 900 ? 0.64 : 0.5), cyp = H * 0.5;
            const left = cxp - sag.boxW / 2, top = cyp - sag.boxH / 2;
            cx.globalAlpha = 0.85 + 0.12 * Math.sin(t * 0.85);
            cx.drawImage(sag.lineCanvas, left - sag.pad, top - sag.pad, sag.lw, sag.lh);
            // a band of light sweeps the saguaro: points shine in turn
            for (const nd of sag.nodes) {
              const wave = Math.sin(t * 1.5 - nd.ny * 5.5 - nd.nx * 2 + nd.ph * 0.5);
              cx.globalAlpha = 0.28 + 0.72 * (0.5 + 0.5 * wave);
              cx.drawImage(sag.dot, left + nd.nx * sag.boxW - sag.ds / 2, top + nd.ny * sag.boxH - sag.ds / 2, sag.ds, sag.ds);
            }
          }
          // drifting neon symbols (slow flicker)
          for (const s of syms) {
            const x = (s.x + Math.sin(t * 0.1 + s.dphx) * 0.03) * W;
            const y = (s.y + Math.cos(t * 0.08 + s.dphy) * 0.04) * H;
            cx.globalAlpha = (dark ? 1 : 0.92) * (0.62 + 0.38 * (0.5 + 0.5 * Math.sin(t * s.sp + s.ph)));
            cx.drawImage(s.sprite.canvas, x - s.sprite.dim / 2, y - s.sprite.dim / 2, s.sprite.dim, s.sprite.dim);
          }
          cx.globalAlpha = 1;
        };

        resize();
        draw(elapsed);
        addEventListener("resize", () => { resize(); draw(elapsed); }, { passive: true });
        addEventListener("themechange", () => { build(); draw(elapsed); });
        if (document.fonts && document.fonts.ready) document.fonts.ready.then(() => { build(); draw(elapsed); });
        if (!reduceBg) {
          const loop = (now: number) => {
            if (!last) last = now;
            let dt = (now - last) / 1000;
            last = now;
            // cap the step so a long stall (background tab, scroll jank, GC pause)
            // can never fast-forward the animation by a visible jump
            if (dt > 0.05) dt = 0.05;
            elapsed += dt;
            draw(elapsed);
            requestAnimationFrame(loop);
          };
          requestAnimationFrame(loop);
        }
      }
    </script>
  </body>
</html>
