---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Sen He — Assistant Professor, ECE, University of Arizona",
  description = "Sen He, Assistant Professor of Electrical & Computer Engineering at the University of Arizona. Research in multi-agent LLM orchestration, software performance engineering, and computer vision.",
} = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (!t)
            t = matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,900&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <canvas id="bg" class="bg-canvas" aria-hidden="true"></canvas>
    <div class="bg-grain" aria-hidden="true"></div>
    <div class="scroll-progress" aria-hidden="true"></div>

    <nav class="nav">
      <a href="/" class="nav-brand">Sen He</a>
      <div class="nav-right">
        <div class="nav-links" id="nav-links">
          <a href="/#research">Research</a>
          <a href="/#publications">Publications</a>
          <a href="/#about">About</a>
        </div>
        <button class="icon-btn" data-theme-toggle aria-label="Toggle light and dark mode">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
        </button>
        <button class="icon-btn nav-toggle" data-menu-toggle aria-label="Open menu" aria-expanded="false" aria-controls="nav-links">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"></path></svg>
        </button>
      </div>
    </nav>

    <main><slot /></main>

    <footer class="footer">
      <div class="wrap" style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:space-between;align-items:center;">
        <span>© {new Date().getFullYear()} Sen He · University of Arizona</span>
        <span style="font-family:var(--font-mono);font-size:0.8rem;">senhe@arizona.edu</span>
      </div>
    </footer>

    <script>
      const nav = document.querySelector(".nav");
      const prog = document.querySelector<HTMLElement>(".scroll-progress");
      const setNav = (y: number) => nav?.classList.toggle("scrolled", y > 8);
      const setProg = (p: number) => {
        if (prog) prog.style.transform = `scaleX(${Math.min(1, Math.max(0, p))})`;
      };

      // mobile menu
      const menuBtn = document.querySelector("[data-menu-toggle]");
      menuBtn?.addEventListener("click", () => {
        const open = nav?.classList.toggle("menu-open");
        menuBtn.setAttribute("aria-expanded", open ? "true" : "false");
      });
      document.querySelectorAll("#nav-links a").forEach((a) =>
        a.addEventListener("click", () => {
          nav?.classList.remove("menu-open");
          menuBtn?.setAttribute("aria-expanded", "false");
        })
      );

      // theme toggle
      document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
        const next =
          document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        try {
          localStorage.setItem("theme", next);
        } catch (e) {}
        dispatchEvent(new Event("themechange"));
      });

      // nav + progress from native scroll — works regardless of rAF / Lenis
      const onScroll = () => {
        const h = document.documentElement;
        const y = window.scrollY || h.scrollTop;
        setProg(y / (h.scrollHeight - h.clientHeight || 1));
        setNav(y);
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
      // ?nolenis disables smooth-scroll hijacking (used for screenshot verification)
      const noLenis = new URLSearchParams(location.search).has("nolenis");

      if (!reduce) {
        document.documentElement.classList.add("has-anim");

        // stagger via --d
        document
          .querySelectorAll<HTMLElement>(".hero .line")
          .forEach((el, i) => el.style.setProperty("--d", `${i * 120}ms`));
        document
          .querySelectorAll<HTMLElement>(".hero .reveal")
          .forEach((el, i) => el.style.setProperty("--d", `${350 + i * 110}ms`));

        // reveals + marker via IntersectionObserver (no rAF dependency)
        const targets = document.querySelectorAll<HTMLElement>(
          ".reveal, .hero .line, .mark"
        );
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.05 }
        );
        targets.forEach((el) => io.observe(el));
        // watchdog: never let anything stay hidden
        setTimeout(() => targets.forEach((el) => el.classList.add("in")), 2600);

        // smooth scroll + parallax enhancement (degrades to native if rAF idle)
        if (!noLenis)
        Promise.all([import("lenis"), import("gsap"), import("gsap/ScrollTrigger")])
          .then(([{ default: Lenis }, { default: gsap }, { ScrollTrigger }]) => {
            gsap.registerPlugin(ScrollTrigger);
            const lenis = new Lenis({ lerp: 0.1 });
            lenis.on("scroll", () => {
              ScrollTrigger.update();
              onScroll();
            });
            gsap.ticker.add((t) => lenis.raf(t * 1000));
            gsap.ticker.lagSmoothing(0);

            gsap.utils.toArray<HTMLElement>("[data-parallax]").forEach((el) => {
              gsap.to(el, {
                yPercent: parseFloat(el.dataset.parallax || "0"),
                ease: "none",
                scrollTrigger: {
                  trigger: ".hero",
                  start: "top top",
                  end: "bottom top",
                  scrub: true,
                },
              });
            });
          })
          .catch(() => {});
      }
    </script>
    <script>
      // Animated background: a Tucson saguaro rendered as a twinkling
      // constellation / point-cloud (futuristic, sci-fi, also reads as an
      // AI network graph), over a drifting starfield with a slow scan line.
      // Draws one frame immediately so it shows even where rAF is paused;
      // loops only when motion is allowed.
      const cv = document.getElementById("bg") as HTMLCanvasElement | null;
      const cx = cv && cv.getContext("2d");
      if (cv && cx) {
        const reduceBg = matchMedia("(prefers-reduced-motion: reduce)").matches;
        const DPR = Math.min(window.devicePixelRatio || 1, 2);
        let W = 0, H = 0;

        // Sample nodes from a saguaro silhouette (trunk + a low-left and a
        // higher-right arm), then precompute a stable neighbour network.
        const saguaro = (() => {
          const o = document.createElement("canvas");
          o.width = 100; o.height = 140;
          const oc = o.getContext("2d")!;
          const bar = (x, y, w, h, r) => {
            oc.beginPath();
            oc.moveTo(x + r, y);
            oc.arcTo(x + w, y, x + w, y + h, r);
            oc.arcTo(x + w, y + h, x, y + h, r);
            oc.arcTo(x, y + h, x, y, r);
            oc.arcTo(x, y, x + w, y, r);
            oc.fill();
          };
          oc.fillStyle = "#fff";
          bar(43, 20, 14, 116, 7);  // trunk
          bar(22, 64, 26, 12, 6);   // left arm — elbow
          bar(22, 40, 12, 30, 6);   // left arm — rises
          bar(54, 52, 26, 12, 6);   // right arm — elbow
          bar(70, 24, 12, 32, 6);   // right arm — rises higher
          const d = oc.getImageData(0, 0, 100, 140).data;
          const pts: any[] = [];
          let tries = 0;
          while (pts.length < 130 && tries < 9000) {
            tries++;
            const x = Math.floor(Math.random() * 100);
            const y = Math.floor(Math.random() * 140);
            if (d[(y * 100 + x) * 4 + 3] > 12)
              pts.push({ nx: x / 100, ny: y / 140, ph: Math.random() * 6.28, sp: 0.5 + Math.random() });
          }
          const pairs: any[] = [];
          for (let i = 0; i < pts.length; i++)
            for (let j = i + 1; j < pts.length; j++) {
              const dd = Math.hypot(pts[i].nx - pts[j].nx, pts[i].ny - pts[j].ny);
              if (dd < 0.095) pairs.push([i, j, dd]);
            }
          return { pts, pairs };
        })();

        let stars: any[] = [];
        const buildStars = () => {
          stars = [];
          const n = Math.round((W * H) / 26000);
          for (let i = 0; i < n; i++)
            stars.push({ x: Math.random(), y: Math.random(), r: Math.random() * 1.1 + 0.3, ph: Math.random() * 6.28, sp: 0.3 + Math.random() * 0.8 });
        };
        const resize = () => {
          W = innerWidth; H = innerHeight;
          cv.width = W * DPR; cv.height = H * DPR;
          cv.style.width = W + "px"; cv.style.height = H + "px";
          cx.setTransform(DPR, 0, 0, DPR, 0, 0);
          buildStars();
        };
        const rect = () => {
          const h = Math.min(H * 0.82, 600);
          const w = h * (100 / 140);
          const cxp = W * (W > 900 ? 0.72 : 0.5);
          return { x: cxp - w / 2, y: (H - h) / 2, w, h };
        };
        const draw = (t: number) => {
          const dark = document.documentElement.dataset.theme === "dark";
          const node = dark ? "152,184,47" : "104,124,18";
          cx.clearRect(0, 0, W, H);
          const R = rect();
          const gx = R.x + R.w / 2, gy = R.y + R.h * 0.45;
          const gl = cx.createRadialGradient(gx, gy, 0, gx, gy, R.h * 0.95);
          gl.addColorStop(0, dark ? "rgba(152,184,47,0.11)" : "rgba(120,140,30,0.06)");
          gl.addColorStop(1, "rgba(0,0,0,0)");
          cx.fillStyle = gl; cx.fillRect(0, 0, W, H);

          for (const s of stars) {
            const tw = 0.35 + 0.65 * (0.5 + 0.5 * Math.sin(t * s.sp + s.ph));
            cx.globalAlpha = (dark ? 0.5 : 0.3) * tw;
            cx.fillStyle = `rgb(${node})`;
            cx.beginPath(); cx.arc(s.x * W, s.y * H, s.r, 0, 6.2832); cx.fill();
          }

          const jx = (p) => R.x + p.nx * R.w + Math.sin(t * 0.5 + p.ph) * 3;
          const jy = (p) => R.y + p.ny * R.h + Math.cos(t * 0.45 + p.ph) * 3;
          cx.lineWidth = 1;
          for (const pr of saguaro.pairs) {
            const a = saguaro.pts[pr[0]], b = saguaro.pts[pr[1]];
            cx.globalAlpha = (dark ? 0.2 : 0.13) * (1 - pr[2] / 0.095);
            cx.strokeStyle = `rgb(${node})`;
            cx.beginPath(); cx.moveTo(jx(a), jy(a)); cx.lineTo(jx(b), jy(b)); cx.stroke();
          }
          for (const p of saguaro.pts) {
            const tw = 0.4 + 0.6 * (0.5 + 0.5 * Math.sin(t * p.sp + p.ph));
            cx.globalAlpha = (dark ? 0.95 : 0.55) * tw;
            cx.fillStyle = `rgb(${node})`;
            cx.beginPath(); cx.arc(jx(p), jy(p), 1.7, 0, 6.2832); cx.fill();
          }
          cx.globalAlpha = 1;

          const scanY = ((t * 0.05) % 1) * H;
          const sg = cx.createLinearGradient(0, scanY - 50, 0, scanY + 50);
          sg.addColorStop(0, `rgba(${node},0)`);
          sg.addColorStop(0.5, `rgba(${node},${dark ? 0.06 : 0.04})`);
          sg.addColorStop(1, `rgba(${node},0)`);
          cx.fillStyle = sg; cx.fillRect(0, scanY - 50, W, 100);
        };
        resize();
        draw(0);
        addEventListener("resize", () => { resize(); draw(performance.now() / 1000); }, { passive: true });
        addEventListener("themechange", () => draw(performance.now() / 1000));
        if (!reduceBg) {
          const loop = (now: number) => { draw(now / 1000); requestAnimationFrame(loop); };
          requestAnimationFrame(loop);
        }
      }
    </script>
  </body>
</html>
